# syntax=docker/dockerfile:1
# Сборка бинарника рассыльщика.
FROM golang:1.23 AS build

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o /out/calendar_sender ./cmd/calendar_sender

FROM alpine:3.20

WORKDIR /app
COPY --from=build /out/calendar_sender /app/calendar_sender
COPY ./configs/sender_docker.yaml /app/configs/sender_docker.yaml

CMD ["/app/calendar_sender", "--config", "/app/configs/sender_docker.yaml"]
