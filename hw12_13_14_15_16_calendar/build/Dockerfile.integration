# syntax=docker/dockerfile:1
# Отдельный образ для запуска integration-тестов внутри docker-compose окружения.
FROM golang:1.23

WORKDIR /tests

COPY go.mod go.sum ./
RUN go mod download

COPY . .

# Запускаем только integration-пакет, чтобы не смешивать с unit-тестами.
CMD ["go", "test", "-v", "./tests/integration/..."]
