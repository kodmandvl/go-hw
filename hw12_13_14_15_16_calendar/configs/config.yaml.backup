logger:
  level: "INFO" # ERROR|WARNING|INFO|DEBUG
  path: "./logs/calendar.log"

storage:
  type: "memory" # memory|sql

http:
  host: "localhost"
  port: 8080

# Конфигурация db необходима, если storage.type - это sql
db:
  dbhost: "localhost"
  dbport: 5435
  dbname: "backend"
  dbusername: "postgres"
  dbpassword: "password"